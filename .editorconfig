# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Rust files
[*.rs]
indent_size = 4
max_line_length = 100

# Kotlin files
[*.kt]
indent_size = 4
max_line_length = 100

# XML files (Android manifests, layouts)
[*.xml]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# TOML files (Cargo.toml)
[*.toml]
indent_size = 2

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Gradle files
[*.gradle]
indent_size = 4

[*.gradle.kts]
indent_size = 4

# PowerShell scripts
[*.ps1]
indent_size = 4

# Batch files
[*.bat]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2
end_of_line = lf
