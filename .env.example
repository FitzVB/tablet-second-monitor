# Environment Configuration Template
# Copy this file to .env and customize for your setup

# ============================================
# Host Server Configuration
# ============================================

# Listen address for WebSocket server
TABLET_MONITOR_LISTEN=0.0.0.0

# Listen port (must match ADB reverse setting)
TABLET_MONITOR_PORT=9001

# ============================================
# Video Encoding Parameters
# ============================================

# Target frames per second (1-120)
TABLET_MONITOR_FPS=60

# Target bitrate in kbps (500-10000)
# Higher = better quality, more bandwidth
TABLET_MONITOR_BITRATE=3500

# Hardware encoder preference
# Options: h264_nvenc (NVIDIA), h264_qsv (Intel), h264_amf (AMD), libx264 (software)
# Leave empty for auto-detection
TABLET_MONITOR_HW_ENCODER=

# ============================================
# Screen Capture
# ============================================

# Capture resolution (width x height)
# Examples: 1920x1080, 1280x720, 960x540
# Leave empty for auto-detect current monitor resolution
TABLET_MONITOR_CAPTURE_WIDTH=1920
TABLET_MONITOR_CAPTURE_HEIGHT=1080

# Downscaling factor (1=no scale, 2=half resolution)
TABLET_MONITOR_SCALE=1

# Fit mode: contain (letterbox) or cover (crop)
TABLET_MONITOR_FIT=cover

# ============================================
# Streaming Mode (Legacy)
# ============================================

# JPEG quality (1-100) - only if using /stream endpoint
# Lower = smaller bandwidth, lower quality
TABLET_MONITOR_JPEG_QUALITY=72

# ============================================
# Logging
# ============================================

# Log level: error, warn, info, debug, trace
RUST_LOG=info

# ============================================
# Development Options
# ============================================

# Enable debug mode (verbose logging)
DEBUG=false

# Skip FFmpeg hardware detection (test software encoder)
FORCE_SOFTWARE_ENCODER=false

# Performance monitoring interval (seconds)
PERF_MONITORING_INTERVAL=30
