<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF121212"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF1E1E1E"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/serverIpInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="PC IP  (127.0.0.1 = USB)"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#99FFFFFF"
                android:backgroundTint="#FF444444"
                android:text="127.0.0.1" />

            <EditText
                android:id="@+id/displayInput"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:hint="Auto"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#99FFFFFF"
                android:backgroundTint="#FF444444"
                android:text="" />

            <Spinner
                android:id="@+id/modeSpinner"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:entries="@array/display_modes"
                android:backgroundTint="#FF444444" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Connect" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textColor="#FFCCCCCC"
            android:text="Estado: desconectado" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/streamContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:visibility="gone">

        <TextureView
            android:id="@+id/streamSurface"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/hudText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:padding="4dp"
            android:textColor="#FFFF00"
            android:textSize="13sp"
            android:background="#99000000"
            android:fontFamily="monospace"
            android:text="" />

    </FrameLayout>

    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FF121212"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textColor="#FF888888"
            android:text="Logs..." />
    </ScrollView>

</LinearLayout>