<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_root"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_panel"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/brandLogo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/logo_content_desc"
                android:src="@drawable/flexdisplay_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/fd_white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/app_subtitle"
                    android:textColor="#FFDCE7FF"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/menuButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/fd_aqua_cyan"
                android:textColor="@color/fd_white"
                android:text="@string/btn_menu" />

            <Button
                android:id="@+id/languageButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/fd_deep_blue_dark"
                android:textColor="@color/fd_white"
                android:text="@string/btn_language" />

            <Button
                android:id="@+id/helpButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/fd_deep_blue_dark"
                android:textColor="@color/fd_white"
                android:text="@string/btn_help" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_pc_ip"
            android:textColor="@color/fd_white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/serverIpInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/hint_pc_ip"
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:text="127.0.0.1"
            android:textColor="@color/fd_white"
            android:textColorHint="#B3FFFFFF"
            android:backgroundTint="@color/fd_aqua_cyan" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/hint_pc_ip_desc"
            android:textColor="#FFD0DCF4"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_display_mode"
                    android:textColor="@color/fd_white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/modeSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:entries="@array/display_modes"
                    android:backgroundTint="@color/fd_aqua_cyan" />
            </LinearLayout>

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_monitor_number"
                    android:textColor="@color/fd_white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/displayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/hint_monitor_auto"
                    android:inputType="number"
                    android:singleLine="true"
                    android:text=""
                    android:textColor="@color/fd_white"
                    android:textColorHint="#B3FFFFFF"
                    android:backgroundTint="@color/fd_aqua_cyan" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/fd_vibrant_orange"
            android:textColor="@color/fd_white"
            android:text="@string/btn_connect" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Switch
                android:id="@+id/hudToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/label_hud"
                android:textColor="@color/fd_white"
                android:thumbTint="@color/fd_aqua_cyan"
                android:trackTint="#80FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#FFE4ECFF"
            android:text="@string/status_disconnected" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/streamContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/fd_stream_bg"
        android:visibility="gone">

        <SurfaceView
            android:id="@+id/streamSurface"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/hudText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:padding="4dp"
            android:textColor="@color/fd_white"
            android:textSize="13sp"
            android:background="@color/fd_hud_bg"
            android:fontFamily="monospace"
            android:text="" />

    </FrameLayout>

    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/fd_soft_bg"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textColor="@color/fd_text_dark"
            android:text="Logs..." />
    </ScrollView>

</LinearLayout>
