<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FlexDisplay" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/fd_deep_blue</item>
        <item name="colorPrimaryDark">@color/fd_deep_blue_dark</item>
        <item name="colorAccent">@color/fd_aqua_cyan</item>
        <!-- Transparent window background: lets SurfaceView render in its own hardware
             overlay layer (below the window) without being covered by the theme color.
             This allows normal View overlays (HUD TextView) to work above the video
             without needing setZOrderOnTop, which would hide those overlays. -->
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
